{
  "name": "river",
  "version": "0.1.0",
  "description": "Physics-based spatial task scheduling MCP server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "river": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
